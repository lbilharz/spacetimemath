{
  "name": "spacetimemath-client",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "concurrently -k -s first \"vite --mode test\" \"wait-on http-get://localhost:5173/ && playwright test\"",
    "test:e2e:headed": "concurrently -k -s first \"vite --mode test\" \"wait-on http-get://localhost:5173/ && playwright test --headed --reporter=list\"",
    "test:e2e:debug": "concurrently -k -s first \"vite --mode test\" \"wait-on http-get://localhost:5173/ && PWDEBUG=1 playwright test\"",
    "lint": "eslint",
    "lint:i18n": "node scripts/check-translations.js",
    "preview": "vite preview",
    "screenshots": "npx ts-node --project tsconfig.node.json scripts/generate-screenshots.ts",
    "agents": "tsx scripts/loadTestAgents.ts",
    "cleanup-bots": "tsx scripts/cleanupBots.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/vite": "^4.2.2",
    "canvas": "^3.2.1",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.6",
    "resend": "^6.9.3",
    "spacetimedb": "2.0.3",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@types/html2canvas": "^0.5.35",
    "@types/node": "^25.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/node": "^5.7.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jiti": "^2.6.1",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.33.4"
    }
  }
}
