  "ar": {
    "badge": "\u0627\u0628\u062a\u0643\u0627\u0631 \u0644\u0644\u062a\u0639\u0644\u064a\u0645 \u0627\u0644\u062a\u0641\u0627\u0639\u0644\u064a \u0648\u0627\u0644\u0641\u0635\u0648\u0644 \u0627\u0644\u0630\u0643\u064a\u0629",
    "s_title": "\u062a\u062f\u0631\u064a\u0628 \u0639\u0644\u0649 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0627\u062a \u0648\u0643\u0623\u0646\u0647 <sw>\u0644\u0639\u0628\u0629</sw>.",
    "s_desc": "\u0627\u0644\u0646\u0647\u062c \u0627\u0644\u062a\u0631\u0628\u0648\u064a \u0627\u0644\u0623\u0643\u062b\u0631 \u0641\u0639\u0627\u0644\u064a\u0629 \u0644\u0625\u062a\u0642\u0627\u0646 \u062c\u062f\u0627\u0648\u0644 \u0627\u0644\u0636\u0631\u0628 \u0628\u0637\u0631\u064a\u0642\u0629 \u0645\u0646\u0647\u062c\u064a\u0629. \u0635\u064f\u0645\u0645 \u0644\u0644\u0645\u0639\u0644\u0645\u064a\u0646 \u0627\u0644\u0645\u0639\u0627\u0635\u0631\u064a\u0646 \u0644\u062a\u0633\u0647\u064a\u0644 \u0627\u0644\u062a\u0642\u064a\u064a\u0645 \u0627\u0644\u062a\u0643\u0648\u064a\u0646\u064a \u0648\u0625\u0644\u0647\u0627\u0645 \u0627\u0644\u0637\u0644\u0627\u0628 \u0628\u0639\u0645\u0642.",
    "sprint_title": "\u0627\u062e\u062a\u0628\u0627\u0631\u0627\u062a \u0645\u0631\u0643\u0632\u0629 \u0644\u0645\u062f\u0629 \u0666\u0660 \u062b\u0627\u0646\u064a\u0629",
    "sprint_desc": "\u0648\u062d\u062f\u0627\u062a \u062a\u0631\u0643\u064a\u0632 \u0642\u0635\u064a\u0631\u0629 \u062c\u062f\u0627\u064b \u0645\u0635\u0645\u0645\u0629 \u0644\u062a\u0642\u0644\u064a\u0644 \u0627\u0644\u0639\u0628\u0621 \u0627\u0644\u0645\u0639\u0631\u0641\u064a \u0648\u0645\u0646\u0639 \u0627\u0644\u0625\u0631\u0647\u0627\u0642. \u062a\u062a\u0643\u0627\u0645\u0644 \u0639\u0636\u0648\u064a\u0627\u064b \u0641\u064a \u0623\u064a \u062e\u0637\u0629 \u062f\u0631\u0648\u0633.",
    "prog_title": "\u0627\u0644\u062e\u0648\u0627\u0631\u0632\u0645\u064a\u0629 \u0627\u0644\u0645\u062a\u0643\u064a\u0641\u0629",
    "prog_desc": "\u064a\u0642\u0648\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0628\u062a\u0639\u062f\u064a\u0644 \u0627\u0644\u062a\u0639\u0642\u064a\u062f \u0627\u0644\u0644\u062d\u0638\u064a \u0628\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0636\u0645\u0646 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0646\u0645\u0648 \u0627\u0644\u0648\u0634\u064a\u0643 \u0627\u0644\u062a\u0627\u0628\u0639\u0629 \u0644\u064a.",
    "friend_title": "\u0639\u0627\u062f\u0627\u062a \u062f\u0631\u0627\u0633\u064a\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u0629",
