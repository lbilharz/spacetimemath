# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do

  # Shared: load ASC API key from env (works locally + in GitHub Actions)
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id:                ENV["ASC_API_KEY_ID"],
      issuer_id:             ENV["ASC_API_KEY_ISSUER_ID"],
      key_content:           ENV["ASC_API_KEY_CONTENT"],
      is_key_content_base64: true
    )
  end

  private_lane :build_web do
    UI.message("Building modern web React app and syncing to Capacitor...")
    sh "cd #{File.join(File.dirname(__FILE__), '../../..')} && npm run build && npx cap sync ios"
  end

  desc "Generate App Store screenshots for all 9 languages via headless browser"
  lane :screenshots do
    sh "cd #{File.join(File.dirname(__FILE__), '../../..')} && npm run screenshots"
  end

  desc "Push metadata and screenshots to App Store Connect (no binary)"
  lane :metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots:   false,
      overwrite_screenshots: true,
      skip_metadata:      false,
      force:              true,
      submit_for_review:  false,
      app_review_information: {
        demo_user: "Teacher Recovery Token",
        demo_password: "3CZNSEC5ZNGK",
        notes: "No username/email is required. To authenticate for your review:\n1) Tap 'Account Recovery' or 'Recovery Key' on the first screen.\n2) Paste the token from the password field: 3CZNSEC5ZNGK\n3) You are now logged in as the demo teacher."
      }
    )
  end

  desc "Full release: screenshots → metadata → build → submit for review"
  lane :release do
    build_web
    screenshots
    deliver(
      skip_binary_upload: true,
      skip_screenshots:   false,
      overwrite_screenshots: true,
      skip_metadata:      false,
      force:              true,
      submit_for_review:  false,
      app_review_information: {
        demo_user: "Teacher Recovery Token",
        demo_password: "3CZNSEC5ZNGK",
        notes: "No username/email is required. To authenticate for your review:\n1) Tap 'Account Recovery' or 'Recovery Key' on the first screen.\n2) Paste the token from the password field: 3CZNSEC5ZNGK\n3) You are now logged in as the demo teacher."
      }
    )
    match(type: "appstore", readonly: true)
    build_app(
      scheme:        "App",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "eu.bilharz.oneup" => "match AppStore eu.bilharz.oneup"
        }
      }
    )
    deliver(
      skip_binary_upload: false,
      skip_screenshots:   true,
      skip_metadata:      true,
      submit_for_review:  true,
      automatic_release:  false,
      app_review_information: {
        demo_user: "Teacher Recovery Token",
        demo_password: "3CZNSEC5ZNGK",
        notes: "No username/email is required. To authenticate for your review:\n1) Tap 'Account Recovery' or 'Recovery Key' on the first screen.\n2) Paste the token from the password field: 3CZNSEC5ZNGK\n3) You are now logged in as the demo teacher."
      }
    )
  end

  desc "CI: build archive and upload to TestFlight only"
  lane :beta do
    build_web
    key = asc_api_key

    # On CI: create a dedicated keychain so match can set cert ACLs
    # without triggering a UI permission popup (login.keychain is locked).
    if ENV['CI']
      keychain_name     = "ci_build.keychain"
      keychain_password = "ci_keychain_pass"
      create_keychain(
        name:               keychain_name,
        password:           keychain_password,
        default_keychain:   true,
        unlock:             true,
        timeout:            3600,
        add_to_search_list: true
      )
      match(
        type:              "appstore",
        readonly:          true,
        api_key:           key,
        keychain_name:     keychain_name,
        keychain_password: keychain_password
      )
    else
      match(type: "appstore", readonly: true, api_key: key)
    end

    # Switch project from Automatic → Manual signing so xcodebuild uses the
    # match profile instead of trying to contact Apple servers at build time.
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "App.xcodeproj",
      team_id:               "2S2J86M3T6",
      bundle_identifier:     "eu.bilharz.oneup",
      code_sign_identity:    "Apple Distribution",
      profile_name:          "match AppStore eu.bilharz.oneup"
    )

    # Automatically fetch the latest build number from TestFlight and increment it by 1 locally
    latest_build_number = app_store_build_number(
      api_key: key,
      app_identifier: "eu.bilharz.oneup",
      version: ENV["MARKETING_VERSION"]
    )
    increment_build_number(
      build_number: latest_build_number + 1,
      xcodeproj: "App.xcodeproj"
    )

    build_app(
      scheme:          "App",
      export_method:   "app-store",
      xcargs:          "-disableAutomaticPackageResolution",
      export_options:  {
        provisioningProfiles: {
          "eu.bilharz.oneup" => "match AppStore eu.bilharz.oneup"
        }
      }
    )

    upload_to_testflight(api_key: key, skip_waiting_for_build_processing: true)
  end

end
